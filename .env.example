# S-Agent Environment Configuration
# Copy this to .env and fill in your values

# Database (Neon Postgres or local PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/dbname?sslmode=require

# AI Provider (Nosana - Qwen3.5)
NOSANA_API_KEY=your_nosana_api_key_here
# Get free key: https://nosana.io/dashboard → API Keys

# Qwen Model (default works)
QWEN_MODEL=qwen-qwen-3-5-27b-awq-4bit
QWEN_ENDPOINT=https://qwen-qwen-3-5-27b-awq-4bit-ff9b2d.us.gateway.dev

# News API (optional, fallback if missing)
CRYPTOPANIC_API_KEY=your_cryptopanic_key_here

# Server
PORT=3001
NODE_ENV=development

