PORT=3001
NODE_ENV=development

# Database (SQLite auto-fallback if unset)
DATABASE_URL=postgresql://user:pass@localhost:5432/sagent
USE_SQLITE=true

# News API - Get free key from https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here

# AI Services
NOSANA_API_KEY=your_nosana_key_here
QWEN_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/text2vec-embeddings

