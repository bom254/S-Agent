# Database - NeonDB PostgreSQL (Required)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Auth - JWT Secret (Required - use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# News API - Get free key from https://cryptopanic.com/developers/api/
